{
  "name": "@est/iconography",
  "version": "0.5.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Authoritative EST iconography sources, metadata, validation and generated SVG distributions.",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "validate": "node scripts/build-assets.mjs --validate-only && node scripts/build-styles.mjs --validate-only",
    "build": "node scripts/build-assets.mjs && node scripts/build-styles.mjs",
    "bundle": "npm run build && node scripts/build-bundle-with-styles.mjs",
    "test:bundle": "node scripts/test-bundle.mjs",
    "test": "npm run validate && npm run build && npm run test:bundle"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "js-yaml": "4.1.0",
    "svgo": "4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
