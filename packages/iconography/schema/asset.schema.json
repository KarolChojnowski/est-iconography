{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EST iconography asset metadata",
  "type": "object",
  "required": [
    "label",
    "family",
    "source",
    "category",
    "tags",
    "status",
    "construction",
    "usage"
  ],
  "properties": {
    "label": { "type": "string", "minLength": 1 },
    "family": { "enum": ["ui-icon", "icon"] },
    "source": { "enum": ["est", "bootstrap"] },
    "category": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "aliases": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "status": { "enum": ["draft", "approved", "deprecated"] },
    "construction": { "enum": ["stroke", "fill"] },
    "usage": { "type": "string", "minLength": 1 },
    "avoid": { "type": "string" },
    "note": { "type": "string" },
    "replaced_by": { "type": "string" },
    "source_name": { "type": "string" },
    "source_version": { "type": "string" },
    "license": { "type": "string" }
  },
  "additionalProperties": false
}
